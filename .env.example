# =============================================================================
# .env.example — Modelo de variáveis de ambiente do SEMANTIC ACADEMIC HUB (BASI)
# -----------------------------------------------------------------------------
# COMO USAR:
#   1. Copie este ficheiro para ".env"   ->  cp .env.example .env
#   2. Ajuste os valores conforme o seu ambiente.
#   3. NUNCA faça commit do ".env" real (já está no .gitignore).
#
# Este ficheiro é lido pelo docker-compose.yml e pelo backend (app/core/config.py).
# =============================================================================

# -----------------------------------------------------------------------------
# Ambiente
# -----------------------------------------------------------------------------
APP_ENV=development                # development | production
APP_NAME=Semantic Academic Hub
APP_VERSION=1.0.0
# Em produção (ex.: Render) coloque 1 para semear a BD e carregar a ontologia no
# Fuseki no arranque, de forma automática e idempotente. Localmente deixe vazio.
BOOTSTRAP_ON_STARTUP=

# -----------------------------------------------------------------------------
# Base de Dados Relacional (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=basi
POSTGRES_PASSWORD=basi_password
POSTGRES_DB=basi
POSTGRES_HOST=postgres            # nome do serviço no docker-compose
POSTGRES_PORT=5432
# String de ligação usada pelo SQLAlchemy (driver psycopg / asyncpg conforme app)
DATABASE_URL=postgresql+psycopg://basi:basi_password@postgres:5432/basi

# -----------------------------------------------------------------------------
# Motor Semântico (Apache Jena Fuseki)
# -----------------------------------------------------------------------------
FUSEKI_ADMIN_PASSWORD=admin
FUSEKI_DATASET=basi
# Endpoints SPARQL (query/update) consumidos pelo backend
FUSEKI_QUERY_ENDPOINT=http://fuseki:3030/basi/query
FUSEKI_UPDATE_ENDPOINT=http://fuseki:3030/basi/update
FUSEKI_DATA_ENDPOINT=http://fuseki:3030/basi/data

# -----------------------------------------------------------------------------
# Armazenamento de Ficheiros (MinIO — compatível com S3)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=basi-documentos
MINIO_SECURE=false                # true em produção (HTTPS)

# -----------------------------------------------------------------------------
# Segurança / Autenticação (JWT)
# -----------------------------------------------------------------------------
# Gere uma chave forte:  openssl rand -hex 32
JWT_SECRET_KEY=troque-esta-chave-por-uma-aleatoria-de-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS — origens autorizadas a chamar a API (frontend)
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend (Next.js) — URL pública da API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
